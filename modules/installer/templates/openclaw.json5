// ============================================================================
//  OpenClaw Elite Wrapper — Hardened Configuration Template
//  By 67Lab.ai
//
//  ⚠️  This file is auto-generated by setup.sh.
//  Placeholders ({{...}}) are injected during installation.
//  Manual edits are safe but may be overwritten on re-install.
// ============================================================================
{
  // ── Identity ─────────────────────────────────────────────────────────────
  "name": "Elite Lobster",
  "version": "1.0.0",

  // ── API Configuration ────────────────────────────────────────────────────
  "api": {
    "provider": "anthropic",            // "anthropic" | "openai" | "ollama"
    "apiKey": "{{ANTHROPIC_API_KEY}}",
    "model": "claude-sonnet-4-20250514",

    // Budget Guardrails (Action 3: Prevent Wallet Heart Attacks)
    "budgetGuardrails": {
      "enabled": true,
      "maxDailySpendUSD": {{MAX_DAILY_SPEND_USD}},
      "maxTokensPerRequest": 4096,
      "maxRequestsPerMinute": 10,
      "maxRequestsPerDay": 500,
      "alertThresholdPercent": 80       // Warn when 80% of daily budget is used
    }
  },

  // ── Soul / Persona ───────────────────────────────────────────────────────
  "soul": {
    "file": "{{SOUL_FILE}}",
    "overrideSystemPrompt": false        // true = soul replaces default prompt
  },

  // ── Telegram Bot Integration ─────────────────────────────────────────────
  "telegram": {
    "enabled": false,                    // Set to true if token is provided
    "botToken": "{{TELEGRAM_BOT_TOKEN}}",
    "allowedChatIds": [],                // Restrict to specific chats
    "replyToGroupMessages": false,       // Prevent leaking secrets in groups
    "maxMessageLength": 4096
  },

  // ── Tool Whitelisting (The Logic Spine) ──────────────────────────────────
  // 🔒 SECURITY: Only enable what the client actually needs.
  "tools": {
    // --- BLOCKED BY DEFAULT (Dangerous) ---
    "exec": {
      "enabled": false,                  // ⛔ Can run arbitrary commands
      "reason": "Disabled for security. Enable only for advanced users."
    },
    "shell": {
      "enabled": false,                  // ⛔ Direct shell access
      "reason": "Disabled for security. Enable only for advanced users."
    },
    "sudo": {
      "enabled": false,                  // ⛔ Privilege escalation
      "reason": "Permanently disabled in Elite Wrapper."
    },

    // --- ALLOWED (Safe) ---
    "browser": {
      "enabled": true,
      "headless": true,                  // No VNC window = no privacy panic
      "maxTabs": 3
    },
    "fileRead": {
      "enabled": true,
      "allowedPaths": [                  // Restrict to workspace only
        "/app/workspace",
        "/app/skills",
        "/app/memory"
      ]
    },
    "fileWrite": {
      "enabled": true,
      "allowedPaths": [
        "/app/workspace",
        "/app/memory"
      ],
      "blockedExtensions": [".sh", ".bash", ".py", ".exe", ".bat"]
    },
    "web_search": {
      "enabled": true
    },
    "code_interpreter": {
      "enabled": true,
      "sandboxed": true                  // Run inside container only
    }
  },

  // ── The Logic Spine (Exfiltration Blocker) ───────────────────────────────
  // Blocks commands that look like data theft attempts.
  "securityFilters": {
    "enabled": true,
    "blockedCommands": [
      "curl",                            // No sending data to external servers
      "wget",
      "nc",                              // Netcat
      "ncat",
      "scp",
      "rsync",
      "ftp",
      "ssh"
    ],
    "blockedPatterns": [
      "rm -rf /",                        // Nuclear option
      "rm -rf /*",
      "mkfs",                            // Disk formatting
      "dd if=",                          // Raw disk writes
      "> /dev/sd",                       // Direct device writes
      "chmod 777",                       // Overly permissive
      "passwd"                           // Password changes
    ],
    "allowedExternalDomains": [
      "api.anthropic.com",
      "api.openai.com",
      "api.telegram.org"
    ]
  },

  // ── Browser Settings ─────────────────────────────────────────────────────
  "browser": {
    "headless": true,
    "userDataDir": "/app/memory/Default",
    "args": [
      "--no-sandbox",                    // Required inside Docker
      "--disable-dev-shm-usage",
      "--disable-gpu",
      "--disable-extensions",
      "--disable-background-networking",
      "--disable-default-apps"
    ]
  },

  // ── Memory & Persistence ─────────────────────────────────────────────────
  "memory": {
    "persistPath": "/app/memory",
    "maxMemorySizeMB": 512,
    "autoCleanupDays": 30               // Clear memories older than 30 days
  },

  // ── Execution Limits (Prevent Infinite Loops) ────────────────────────────
  "execution": {
    "maxStepsPerTask": 50,               // Hard stop after 50 actions
    "maxConsecutiveErrors": 5,           // Stop if AI fails 5 times in a row
    "taskTimeoutMinutes": 30,            // Kill tasks running > 30 min
    "cooldownBetweenTasksMs": 2000       // 2 second cooldown
  }
}
